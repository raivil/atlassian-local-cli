WIKI_URL=https://wiki.example.com/
WIKI_USERNAME=your-username
WIKI_TOKEN=your-token-here

JIRA_URL=https://jira.example.com/
JIRA_USERNAME=your-username
JIRA_TOKEN=your-token-here

# Multi-account / context support
# ----------------------------------------------------------------------------
# This file (~/.config/atlassian-local-cli/.env) is the "default" context.
# Additional contexts live at: ~/.config/atlassian-local-cli/contexts/<name>.env
#
# Pick one for a single command:
#     atlassian-local-cli --context work jira-get FOO-1
#
# Make a named context the persistent default:
#     atlassian-local-cli context use work
#
# Inspect or list:
#     atlassian-local-cli context list
#     atlassian-local-cli context show work
